#!/usr/bin/env bash
set -euo pipefail

# Bypass: SKIP_HOOKS=1 git push
[[ "${SKIP_HOOKS:-0}" == "1" ]] && exit 0

# Lê stdin do protocolo pre-push (obrigatório)
while read -r _local_ref _local_sha _remote_ref _remote_sha; do
    :
done

echo "🚀 pre-push: validação completa..."

# Detecta ambiente: Docker ou local
if docker compose ps --status running 2>/dev/null | grep -q 'app'; then
    RUN="docker compose exec -T app"
else
    RUN=""
fi

FAILED=0

# Pint (code style)
echo "  → Pint (code style)..."
if ! $RUN vendor/bin/pint --test 2>&1; then
    echo ""
    echo "  ✗ Pint falhou. Corrija com:"
    echo "    $RUN vendor/bin/pint"
    echo ""
    FAILED=1
fi

# PHPStan (static analysis)
echo "  → PHPStan (análise estática)..."
if ! $RUN vendor/bin/phpstan analyse 2>&1; then
    echo ""
    echo "  ✗ PHPStan encontrou erros."
    echo ""
    FAILED=1
fi

# Testes com cobertura mínima de 80%
echo "  → Testes com cobertura (min 80%)..."
if ! $RUN php artisan test --coverage --min=80 2>&1; then
    echo ""
    echo "  ✗ Testes falharam ou cobertura abaixo de 80%."
    echo ""
    FAILED=1
fi

if [[ $FAILED -eq 1 ]]; then
    echo "❌ pre-push falhou. Corrija os erros acima."
    echo "   Bypass de emergência: SKIP_HOOKS=1 git push ..."
    exit 1
fi

echo "✅ pre-push OK"
