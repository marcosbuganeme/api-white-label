APP_NAME="API MaisVendas"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=maisvendas_test
DB_USERNAME=postgres
DB_PASSWORD=secret

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=maisvendas_test_logs

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

SESSION_DRIVER=redis
QUEUE_CONNECTION=sync
CACHE_STORE=redis

MAIL_MAILER=log
