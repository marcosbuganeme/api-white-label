APP_NAME="API MaisVendas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_DOMAIN=api.maisvendas.localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,mongodb
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── PostgreSQL (banco principal - CRUD, relatórios) ──
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=maisvendas
DB_USERNAME=postgres
DB_PASSWORD=secret

# ── MongoDB (logs, métricas, insumos processados) ──
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=maisvendas_logs

# ── Redis (cache, sessions, filas leves) ──
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ── RabbitMQ (processamento pesado) ──
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=maisvendas
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=maisvendas
RABBITMQ_QUEUE=processing
RABBITMQ_EXCHANGE=maisvendas.processing
RABBITMQ_EXCHANGE_TYPE=topic

# ── Session ──
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Queue (default via Redis, heavy via RabbitMQ) ──
QUEUE_CONNECTION=redis

# ── Cache via Redis ──
CACHE_STORE=redis

# ── Telescope (dev only) ──
TELESCOPE_ENABLED=true

# ── Mail ──
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@maisvendas.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
