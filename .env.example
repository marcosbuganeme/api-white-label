APP_NAME="API MaisVendas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_DOMAIN=api.maisvendas.localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=cache

# -- Docker --
# Target do build Docker: development (default) ou production
DOCKER_TARGET=development

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,mongodb
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_MONGODB_LEVEL=warning

# -- PostgreSQL (banco principal - CRUD, relatorios) --
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=maisvendas
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer
# NOTE: Default do config é 'require'. Em dev local com Docker (sem SSL), use 'prefer'.

# -- MongoDB (logs, metricas, insumos processados) --
# Credenciais devem ser embutidas na URI: mongodb://USER:PASSWORD@HOST:PORT/DB?authSource=admin
MONGODB_URI=mongodb://maisvendas:@mongodb:27017/maisvendas_logs?authSource=admin
MONGODB_DATABASE=maisvendas_logs
MONGODB_USER=maisvendas
MONGODB_PASSWORD=

# -- Redis (cache, sessions, filas leves) --
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_HORIZON_DB=2
REDIS_QUEUE_DB=3
# REDIS_QUEUE_PREFIX= (opcional, default: {APP_NAME}_queue_)

# -- RabbitMQ (processamento pesado) --
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=maisvendas
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=maisvendas
RABBITMQ_QUEUE=processing
RABBITMQ_EXCHANGE=maisvendas.processing
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_MANAGEMENT_PORT=15672
# Htpasswd para BasicAuth do management UI via Traefik. Gere com: htpasswd -nB admin
RABBITMQ_MGMT_HTPASSWD=

# -- Trusted Proxies (Docker network CIDR) --
TRUSTED_PROXIES=172.16.0.0/12

# -- Session (stateless API - override to redis if web UI needed) --
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# -- Queue (default via Redis, heavy via RabbitMQ) --
QUEUE_CONNECTION=redis

# -- Cache via Redis --
CACHE_STORE=redis

# -- CORS (comma-separated origins for whitelabel frontends) --
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_PATTERNS=
CORS_SUPPORTS_CREDENTIALS=false

# -- Sanctum --
# Token expiration in minutes (default: 43200 = 30 days)
SANCTUM_TOKEN_EXPIRATION=43200
# Token prefix for GitHub secret scanning detection
SANCTUM_TOKEN_PREFIX=mvapi_

# -- Horizon --
# Comma-separated list of emails allowed to access /horizon dashboard.
# If empty, dashboard returns 403 for ALL users in non-local environments.
HORIZON_ALLOWED_EMAILS=
HORIZON_MEMORY_LIMIT=128

# -- Telescope (somente APP_ENV=local, ignorado em outros ambientes) --
TELESCOPE_ENABLED=true

# -- Mail --
MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@maisvendas.com"
MAIL_FROM_NAME="${APP_NAME}"

# -- DigitalOcean Spaces (S3-compatible) --
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=white-label-spaces
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_CDN_URL=https://white-label-spaces.nyc3.cdn.digitaloceanspaces.com
